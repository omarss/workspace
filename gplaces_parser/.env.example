# --- Language / region ---
LANGUAGE=ar
REGION=sa

# --- Riyadh bounding box (WGS84) ---
# Default = all of Riyadh. Shrink for a smoke test.
RIYADH_LAT_MIN=24.50
RIYADH_LAT_MAX=25.05
RIYADH_LNG_MIN=46.45
RIYADH_LNG_MAX=47.10
TILE_KM=3.0
SEARCH_RADIUS_KM=2.5
RESULTS_PER_QUERY=400
REVIEWS_PER_PLACE=2000
REVIEWS_SORT=newest
MAX_CONCURRENT_JOBS=1

# --- Playwright ---
# Keep headless=false the first time so you can solve CAPTCHAs manually.
SCRAPER_HEADLESS=false
SCRAPER_SLOW_MO_MS=0
SCRAPER_DELAY_SECONDS=3.0
SCRAPER_PAGE_TIMEOUT_MS=30000
SCRAPER_SCROLL_PAUSE_MS=2200
SCRAPER_MAX_SCROLLS=80

# --- Postgres (created by `make db-create`) ---
DATABASE_URL=postgresql://gplaces:gplaces@localhost:5432/gplaces

# --- FastAPI /v1/nearby (see FEEDBACK.md) ---
# GPLACES_API_KEY: generate once with `openssl rand -hex 32`, mirror the
# same value into omono's local.properties as `gplaces.api.key`.
GPLACES_API_KEY=
API_HOST=0.0.0.0
API_PORT=8000
API_DEFAULT_LIMIT=25
API_MAX_LIMIT=50
