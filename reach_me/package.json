{
  "name": "reach_me",
  "version": "0.1.0",
  "description": "Self-hosted POC service for sending confirmation requests over multiple channels.",
  "private": true,
  "license": "UNLICENSED",
  "packageManager": "bun@1.3.5",
  "engines": {
    "bun": ">=1.3.5"
  },
  "scripts": {
    "start": "bun dist/main.js",
    "start:dev": "bunx nest start --watch",
    "build": "bunx nest build",
    "lint": "bunx eslint \"{src,test}/**/*.ts\" --max-warnings=0",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "format": "bunx prettier --write \"src/**/*.ts\" \"test/**/*.ts\""
  },
  "dependencies": {
    "@nestjs/common": "^11.1.12",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.12",
    "@nestjs/platform-express": "^11.1.12",
    "@nestjs/throttler": "^6.5.0",
    "cassandra-driver": "^4.8.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "pg-boss": "^12.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.12",
    "@eslint/js": "^9.39.2",
    "@types/bun": "^1.3.6",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.7",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.0.0",
    "prettier": "^3.8.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
