# --- Postgres (created by `make db-create`) ---
DATABASE_URL=postgresql://mcqs:mcqs@localhost:5432/mcqs

# --- Docs corpus ---
# Root of the vrtx-ai docs-bundle. Every top-level subdirectory becomes one
# "subject" in the question bank (java25/, spring-boot-4/, kubernetes/, ...).
DOCS_BUNDLE_ROOT=/home/omar/workspace/vrtx-ai/docs-bundle

# --- Anthropic (MCQ generation) ---
# Get a key from https://console.anthropic.com and paste it here.
ANTHROPIC_API_KEY=
# Model used for generation. Sonnet 4.6 is the approved default.
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- FastAPI /v1/mcq ---
# Generate once with `openssl rand -hex 32`. Independent of GPLACES_API_KEY.
MCQS_API_KEY=
API_HOST=0.0.0.0
API_PORT=8000
API_DEFAULT_LIMIT=25
API_MAX_LIMIT=100

# --- Generation tuning ---
# Questions produced per Claude call. Lower = more variety, more API calls.
MCQS_BATCH_SIZE=10
# Target count per (subject, round, type). The task spec floor is 100.
MCQS_PER_TYPE_TARGET=100
# Chunking ceiling (rough token budget per chunk); overlap carries context
# across boundaries so a split never orphans the answer to a question.
MCQS_CHUNK_TOKENS=1000
MCQS_CHUNK_OVERLAP=150
