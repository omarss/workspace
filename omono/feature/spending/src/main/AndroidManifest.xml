<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
      Reading bank transaction SMSes. Only READ_SMS is needed — the
      feature watches for new SMSes via a ContentObserver on
      Telephony.Sms.CONTENT_URI, which doesn't need the dangerous
      RECEIVE_SMS permission that a manifest-registered BroadcastReceiver
      would.
    -->
    <uses-permission android:name="android.permission.READ_SMS" />

</manifest>
