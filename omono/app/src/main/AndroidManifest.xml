<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Location: precise + background for continuous tracking off-app. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- Foreground service + its feature-specific subtype. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />

    <!-- Ongoing notification (Android 13+). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Auto-start after reboot. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Defensive: the foreground service implicitly holds a partial wake
         lock, but FusedLocationProvider can briefly need an explicit one
         during cold-start GPS scans. -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Lets the app launch the system "ignore battery optimisation"
         confirmation dialog directly so the user can whitelist us in
         one tap. Not allowed on Play Store unless the app falls in a
         specific category, but we sideload via Obtainium. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Network access for the OSM Overpass speed-limit lookup and the
         self-update check against the apps.omarss.net manifest. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Self-updater: lets omono hand a freshly downloaded APK to the
         system installer. Android still shows the confirmation dialog —
         this permission just allows us to *launch* that dialog without
         the user digging through settings first. Merged from
         :feature:selfupdate but duplicated here for visibility. -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <!-- Temporarily raises alarm volume during the over-limit beep and
         restores it afterwards. Normal permission, granted at install. -->
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />

    <!-- Lets us temporarily call setInterruptionFilter(ALL) to make the
         over-limit tone audible even in Do Not Disturb. The declaration
         itself is a normal permission; the user still has to grant
         "Do Not Disturb access" via system settings for it to take
         effect — the app surfaces a card that deep-links to the right
         page when the user has alerts enabled. -->
    <uses-permission android:name="android.permission.ACCESS_NOTIFICATION_POLICY" />

    <!-- Spending feature: reads the SMS inbox (Al Rajhi Bank + STC Bank
         transaction messages only, filtered at query time) and watches
         for new ones to keep the today/month totals fresh. Both are
         dangerous runtime permissions — the main screen guides the
         user through granting them, and the feature emits an error
         state when they aren't. -->
    <uses-permission android:name="android.permission.READ_SMS" />
    <uses-permission android:name="android.permission.RECEIVE_SMS" />

    <!-- Declare GPS as optional hardware so devices without GPS can still install. -->
    <uses-feature
        android:name="android.hardware.location.gps"
        android:required="false" />

    <!-- Telephony is optional too — READ_SMS / RECEIVE_SMS normally imply
         a hardware requirement, but omono is a driver-assist app that
         still renders the speedometer fine on SMS-less devices. -->
    <uses-feature
        android:name="android.hardware.telephony"
        android:required="false" />

    <application
        android:name=".OmonoApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="false"
        android:hasFragileUserData="false"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Omono">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.Omono">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name="net.omarss.omono.core.service.FeatureHostService"
            android:exported="false"
            android:foregroundServiceType="location"
            tools:ignore="Instantiatable" />

        <receiver
            android:name=".BootReceiver"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.RECEIVE_BOOT_COMPLETED">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- FileProvider for sharing cache-dir files (currently the
             bank-SMS export) with other apps via ACTION_SEND without
             leaking arbitrary filesystem paths. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Quick Settings tile: one-tap start/stop from the system
             pull-down without opening the app. BIND_QUICK_SETTINGS_TILE
             is granted automatically by the platform binding the
             TileService. -->
        <service
            android:name=".OmonoTileService"
            android:label="@string/app_name"
            android:icon="@drawable/ic_launcher_monochrome"
            android:exported="true"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
            <meta-data
                android:name="android.service.quicksettings.ACTIVE_TILE"
                android:value="true" />
        </service>

    </application>
</manifest>
