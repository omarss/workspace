# Option A: Anthropic API key (direct API access)
# ANTHROPIC_API_KEY=sk-ant-...

# Option B: OpenAI-compatible proxy (e.g. claude-max-api for Claude Max subscribers)
# Start the proxy: claude-max-api
# Then set:
# SWET_CLI_BASE_URL=http://localhost:3456/v1

# Optional: Override default models
# For direct API: claude-sonnet-4-6 (default)
# For proxy: claude-sonnet-4 (default)
# SWET_CLI_GEN_MODEL=claude-sonnet-4
# SWET_CLI_GRADE_MODEL=claude-sonnet-4

# Optional: Override database path (default: ~/.local/share/swet_cli/swet.db)
# SWET_CLI_DB_PATH=/path/to/swet.db
