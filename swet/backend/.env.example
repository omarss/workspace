# Database
DATABASE_URL=postgresql+asyncpg://swet:swet_local@localhost:5432/swet

# Auth
NEXTAUTH_SECRET=your-nextauth-secret-here

# AI - Direct Anthropic API (default)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# AI - OpenAI-compatible proxy (optional, overrides direct Anthropic)
# LLM_BASE_URL=http://127.0.0.1:3456/v1
# LLM_API_KEY=not-needed

# AI - Model overrides (defaults to claude-sonnet-4-6 for both)
# LLM_GENERATION_MODEL=claude-sonnet-4-6
# LLM_GRADING_MODEL=claude-sonnet-4-6

# App
APP_ENV=development
CORS_ORIGINS=http://localhost:3000
