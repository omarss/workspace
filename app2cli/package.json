{
  "name": "app2cli",
  "version": "0.1.0",
  "description": "Convert live web apps and Android APKs into structured, machine-readable UI representations from the CLI",
  "type": "module",
  "bin": {
    "app2cli": "./dist/cli/main.js"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');fs.chmodSync('dist/cli/main.js',0o755)\"",
    "prepare": "git config core.hooksPath .githooks",
    "prepublishOnly": "pnpm check && pnpm build",
    "lint": "eslint src/ --max-warnings 0",
    "lint:fix": "eslint src/ --fix --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "dev": "tsx src/cli/main.ts",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "audit:repo": "node scripts/audit.mjs",
    "audit:repo:json": "node scripts/audit.mjs --json",
    "audit:deps": "pnpm audit --prod"
  },
  "keywords": [
    "cli",
    "web-automation",
    "android",
    "accessibility",
    "ui-testing",
    "playwright",
    "appium"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "fast-xml-parser": "^5.5.10",
    "playwright-core": "^1.59.1",
    "tesseract.js": "^7.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.2",
    "eslint": "^10.1.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "tesseract.js"
    ]
  }
}
